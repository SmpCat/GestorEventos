// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------
// MODELO GLOBAL
// ---------------------------------------------------------

model User {
  id             String          @id @default(uuid())
  name           String
  username       String          @unique
  password       String
  email          String?
  phone          String?
  isAdmin        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  // Relaciones
  eventAttendances EventAttendee[]
  expenses         Expense[]
}

// ---------------------------------------------------------
// MODELOS ESPECÍFICOS POR EVENTO (MULTI-TENANT)
// ---------------------------------------------------------

model Event {
  id          String   @id @default(uuid())
  name        String   // ej. "Fiestas Valdeganga 2026"
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(false) // Solo UNO puede ser true
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  attendees    EventAttendee[]
  pricingRules PricingRule[]
  expenses     Expense[]
}

model EventAttendee {
  id            String   @id @default(uuid())
  daysAttending Int      @default(0)
  hasPaid       Boolean  @default(false)
  balance       Float    @default(0.0) // Saldo a favor en ESTE evento
  
  // Relaciones
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Un usuario solo puede asistir una vez a un mismo evento
  @@unique([userId, eventId])
}

model PricingRule {
  id        String   @id @default(uuid())
  days      Int
  price     Float
  
  // Relaciones
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, days])
}

model Expense {
  id           String   @id @default(uuid())
  description  String
  store        String
  amount       Float
  date         DateTime @default(now())
  
  // Relaciones
  purchaserId  String
  purchaser    User     @relation(fields: [purchaserId], references: [id])
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  // Soporte para tickets muy largos e inventario de productos (Extraídos por IA)
  images       ExpenseImage[]
  items        ExpenseItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ExpenseImage {
  id        String   @id @default(uuid())
  url       String   // Ruta de la imagen (o varias si el ticket es largo)
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model ExpenseItem {
  id        String   @id @default(uuid())
  name      String   // Nombre del producto (ej. "Cerveza Alhambra")
  price     Float    // Precio del producto
  quantity  Int      @default(1)
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}
