// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// MODELO GLOBAL
// ---------------------------------------------------------

model User {
  id             String          @id @default(uuid())
  name           String
  username       String          @unique
  password       String
  email          String?
  phone          String?
  isAdmin        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  // Relaciones
  eventAttendances EventAttendee[]
  expenses         Expense[]
  shoppingTasks    ShoppingListItem[] // Tareas de compra asignadas
  
  // Auditoría
  attendanceHistoryChanges AttendanceHistory[] @relation("HistoryChangedBy")
  registeredPayments       Payment[]           @relation("PaymentRegisteredBy")
}

// ---------------------------------------------------------
// MODELOS ESPECÍFICOS POR EVENTO (MULTI-TENANT)
// ---------------------------------------------------------

model Event {
  id          String   @id @default(uuid())
  name        String   // ej. "Fiestas Valdeganga 2026"
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(false) // Solo UNO puede ser true
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  attendees       EventAttendee[]
  pricingRules    PricingRule[]
  expenses        Expense[]
  shoppingList    ShoppingListItem[]
  shoppingEvidences ShoppingListEvidence[]
}

model EventAttendee {
  id            String   @id @default(uuid())
  daysAttending Int      @default(0)
  balance       Float    @default(0.0) // Saldo a favor en ESTE evento
  
  // Custom Pricing (Nuevos campos)
  expectedPayment Float?   // Lo que tiene que pagar. Nulo = automático según tabla.
  adminComment    String?  // Comentario del admin si sobrescribe el precio.
  
  // Relaciones
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Un usuario solo puede asistir una vez a un mismo evento
  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])

  // Pagos realizados por el asistente
  payments      Payment[]
  
  // Historial de cambios de días
  history       AttendanceHistory[] @relation("AttendeeHistory")
}

model Payment {
  id          String   @id @default(uuid())
  amount      Float
  date        DateTime @default(now())
  
  attendeeId  String
  attendee    EventAttendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  // Auditoría
  registeredById String?
  registeredBy   User?   @relation("PaymentRegisteredBy", fields: [registeredById], references: [id])

  @@index([attendeeId])
  @@index([registeredById])
}

model PricingRule {
  id        String   @id @default(uuid())
  days      Int
  price     Float
  
  // Relaciones
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, days])
  @@index([eventId])
}

model ShoppingListItem {
  id          String   @id @default(uuid())
  name        String   // ej. "100 cervezas"
  isPurchased Boolean  @default(false)
  
  // Relación con el Evento
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  // Asignado a alguien para que lo compre (Opcional)
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  
  // Vinculado al ticket final cuando ya se ha comprado (Opcional)
  expenseItemId String? @unique
  expenseItem   ExpenseItem? @relation(fields: [expenseItemId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId])
  @@index([assigneeId])
}

model ShoppingListEvidence {
  id        String   @id @default(uuid())
  url       String   // Ruta física o URL de la imagen
  createdAt DateTime @default(now())
  
  // Relaciones
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Expense {
  id           String   @id @default(uuid())
  description  String
  store        String
  amount       Float
  date         DateTime @default(now())
  
  // Relaciones
  purchaserId  String
  purchaser    User     @relation(fields: [purchaserId], references: [id])
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  // Soporte para tickets muy largos e inventario de productos (Extraídos por IA)
  images       ExpenseImage[]
  items        ExpenseItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
  @@index([purchaserId])
}

model ExpenseImage {
  id        String   @id @default(uuid())
  url       String   // Ruta de la imagen (o varias si el ticket es largo)
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}

model ExpenseItem {
  id        String   @id @default(uuid())
  name      String   // Nombre del producto (ej. "Cerveza Alhambra")
  price     Float    // Precio del producto
  quantity  Int      @default(1)
  expenseId String
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  
  // Relación inversa con la lista de la compra
  shoppingListItem ShoppingListItem?

  @@index([expenseId])
}

// ---------------------------------------------------------
// MODELOS DE AUDITORÍA Y REGISTRO
// ---------------------------------------------------------

model AttendanceHistory {
  id          String   @id @default(uuid())
  attendeeId  String
  attendee    EventAttendee @relation("AttendeeHistory", fields: [attendeeId], references: [id], onDelete: Cascade)
  
  oldDays     Int      // Días que tenía antes (0 si es nuevo)
  newDays     Int      // Días nuevos asignados
  
  // Usuario que hizo el cambio
  changedById String
  changedBy   User     @relation("HistoryChangedBy", fields: [changedById], references: [id])
  
  date        DateTime @default(now())

  @@index([attendeeId])
  @@index([changedById])
}
